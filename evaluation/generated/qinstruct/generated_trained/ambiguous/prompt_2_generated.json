{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Film",
  "description": "Schema for Film",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    },
    "genre": {
      "type": "string"
    },
    "director": {
      "type": "string"
    },
    "actors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "rating": {
      "type": "number"
    },
    "duration": {
      "type": "number"
    },
    "image_url": {
      "type": "string"
    },
    "video_url": {
      "type": "string"
    },
    "release_date": {
      "type": "string"
    },
    "cast": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}