{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Travel Booking System",
  "description": "Schema for the Travel Booking System",
  "type": "object",
  "properties": {
    "booking": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "price": {
            "type": "number"
          }
        }
      }
    }
  }
}