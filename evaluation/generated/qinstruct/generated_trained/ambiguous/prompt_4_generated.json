{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "eCommerce Product Catalog",
  "description": "Schema for e-commerce product catalog.",
  "type": "object",
  "properties": {
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "quantity": {
            "type": "integer"
          }
        },
        "required": [
          "id",
          "name",
          "price",
          "quantity"
        ]
      }
    }
  },
  "additionalProperties": true
}