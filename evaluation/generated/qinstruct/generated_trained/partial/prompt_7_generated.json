{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "postId": {
      "type": "string"
    },
    "userId": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "media": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "likes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "commentText": {
            "type": "string"
          }
        }
      }
    },
    "createdAt": {
      "type": "string"
    }
  }
}