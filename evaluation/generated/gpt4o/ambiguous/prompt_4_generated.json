{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "E-commerce Product Catalog",
  "type": "object",
  "properties": {
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "description": "A unique identifier for the product."
          },
          "name": {
            "type": "string",
            "description": "The name of the product."
          },
          "description": {
            "type": "string",
            "description": "A detailed description of the product."
          },
          "price": {
            "type": "number",
            "description": "The price of the product.",
            "minimum": 0
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the product price, e.g., USD, EUR."
          },
          "category": {
            "type": "string",
            "description": "The category to which the product belongs."
          },
          "stock": {
            "type": "integer",
            "description": "The number of items available in stock.",
            "minimum": 0
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri",
              "description": "A URL to an image of the product."
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "Tags associated with the product for search optimization."
            }
          },
          "dimensions": {
            "type": "object",
            "properties": {
              "length": {
                "type": "number",
                "description": "The length of the product.",
                "minimum": 0
              },
              "width": {
                "type": "number",
                "description": "The width of the product.",
                "minimum": 0
              },
              "height": {
                "type": "number",
                "description": "The height of the product.",
                "minimum": 0
              },
              "weight": {
                "type": "number",
                "description": "The weight of the product.",
                "minimum": 0
              }
            },
            "required": ["length", "width", "height", "weight"]
          },
          "manufacturer": {
            "type": "string",
            "description": "The manufacturer of the product."
          },
          "sku": {
            "type": "string",
            "description": "The stock keeping unit identifier for the product."
          },
          "releaseDate": {
            "type": "string",
            "format": "date",
            "description": "The release date of the product."
          }
        },
        "required": ["productId", "name", "price", "currency", "category", "stock"]
      }
    }
  },
  "required": ["products"]
}