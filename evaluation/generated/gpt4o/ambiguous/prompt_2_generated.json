{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Film",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "The title of the film."
    },
    "director": {
      "type": "string",
      "description": "The director of the film."
    },
    "releaseYear": {
      "type": "integer",
      "description": "The year the film was released.",
      "minimum": 1888
    },
    "genre": {
      "type": "array",
      "description": "The genre(s) of the film.",
      "items": {
        "type": "string"
      }
    },
    "duration": {
      "type": "integer",
      "description": "The duration of the film in minutes.",
      "minimum": 1
    },
    "cast": {
      "type": "array",
      "description": "The main cast of the film.",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the cast member."
          },
          "role": {
            "type": "string",
            "description": "The role played by the cast member."
          }
        },
        "required": ["name", "role"]
      }
    },
    "rating": {
      "type": "number",
      "description": "The average rating of the film.",
      "minimum": 0,
      "maximum": 10
    },
    "language": {
      "type": "string",
      "description": "The primary language of the film."
    },
    "subtitles": {
      "type": "array",
      "description": "Available subtitle languages for the film.",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["title", "director", "releaseYear", "genre", "duration"]
}