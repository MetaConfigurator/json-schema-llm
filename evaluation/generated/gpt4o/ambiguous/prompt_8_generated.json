{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Job Application",
  "type": "object",
  "properties": {
    "applicant": {
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "minLength": 1
        },
        "lastName": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "pattern": "^\\+?[1-9]\\d{1,14}$"
        },
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string"
            },
            "postalCode": {
              "type": "string",
              "pattern": "^\\d{5}(-\\d{4})?$"
            },
            "country": {
              "type": "string"
            }
          },
          "required": ["street", "city", "state", "postalCode", "country"]
        }
      },
      "required": ["firstName", "lastName", "email", "phone", "address"]
    },
    "jobDetails": {
      "type": "object",
      "properties": {
        "jobId": {
          "type": "string"
        },
        "position": {
          "type": "string"
        },
        "department": {
          "type": "string"
        },
        "location": {
          "type": "string"
        }
      },
      "required": ["jobId", "position", "department", "location"]
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "institution": {
            "type": "string"
          },
          "degree": {
            "type": "string"
          },
          "fieldOfStudy": {
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": "string",
            "format": "date"
          }
        },
        "required": ["institution", "degree", "fieldOfStudy", "startDate", "endDate"]
      }
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "company": {
            "type": "string"
          },
          "position": {
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": "string",
            "format": "date"
          },
          "responsibilities": {
            "type": "string"
          }
        },
        "required": ["company", "position", "startDate", "endDate", "responsibilities"]
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "relationship": {
            "type": "string"
          },
          "contact": {
            "type": "string"
          }
        },
        "required": ["name", "relationship", "contact"]
      }
    },
    "coverLetter": {
      "type": "string"
    },
    "resume": {
      "type": "string",
      "format": "uri"
    }
  },
  "required": ["applicant", "jobDetails", "education", "experience", "skills", "coverLetter", "resume"]
}