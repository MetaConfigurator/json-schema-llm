{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "patientId": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "dateOfBirth": {
      "type": "string",
      "format": "date"
    },
    "gender": {
      "type": "string",
      "enum": ["male", "female", "other"]
    },
    "contactInfo": {
      "type": "object",
      "properties": {
        "phone": {
          "type": "string",
          "pattern": "^\\+?[1-9]\\d{1,14}$"
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      },
      "required": ["phone", "email"]
    },
    "medicalHistory": {
      "type": "object",
      "properties": {
        "condition": {
          "type": "string"
        },
        "diagnosisDate": {
          "type": "string",
          "format": "date"
        },
        "medication": {
          "type": "string"
        }
      },
      "required": ["condition", "diagnosisDate", "medication"]
    },
    "allergies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["patientId", "name", "dateOfBirth", "gender", "contactInfo", "medicalHistory", "createdAt"]
}