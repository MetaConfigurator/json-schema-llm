{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Book",
  "description": "Represents a book in a catalog.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "publicationYear": {
      "type": "integer",
      "minimum": 1450
    },
    "price": {
      "type": "number",
      "minimum": 0
    },
    "genre": {
      "type": "string",
      "pattern": "^\\d{3}-\\d{10}$"
    },
    "isbn": {
      "type": "string",
      "pattern": "^\\d{3}-\\d{10}$"
    }
  },
  "required": [
    "title",
    "author",
    "price",
    "isbn"
  ]
}