{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "orderId": {
      "type": "string"
    },
    "customer": {
      "type": "object",
      "properties": {
        "customerId": {
          "type": "integer"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        }
      },
      "required": [
        "customerId",
        "email",
        "phone"
      ]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "integer"
          },
          "quantity": {
            "type": "integer"
          },
          "unitPrice": {
            "type": "number"
          }
        },
        "required": [
          "productId",
          "quantity",
          "unitPrice"
        ]
      }
    },
    "orderDate": {
      "type": "string"
    },
    "totalAmount": {
      "type": "number"
    }
  },
  "required": [
    "orderId",
    "customer",
    "items",
    "orderDate",
    "totalAmount"
  ],
  "additionalProperties": false
}