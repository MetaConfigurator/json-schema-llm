{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "postId": {
      "type": "string"
    },
    "userId": {
      "type": "integer"
    },
    "content": {
      "type": "string"
    },
    "media": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "url"
        ]
      }
    },
    "likes": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer"
          },
          "commentText": {
            "type": "string"
          }
        },
        "required": [
          "userId",
          "commentText"
        ]
      }
    },
    "createdAt": {
      "type": "string"
    }
  },
  "required": [
    "postId",
    "userId",
    "content",
    "media",
    "likes",
    "comments",
    "createdAt"
  ],
  "additionalProperties": false
}