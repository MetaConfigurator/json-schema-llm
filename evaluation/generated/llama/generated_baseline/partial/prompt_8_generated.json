{ 
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Sensor Reading",
    "type": "object",
    "properties": {
        "sensorId": {"type": "string", "description": "Unique identifier of the sensor"},
        "type": {"type": "string", "enum": ["temperature", "humidity", "pressure"], "description": "Type of measurement"}
    },
    "required": ["sensorId", "type"],
    "additionalProperties": false,
    "additionalType": null,
    "oneOf": [
        {
            "type": "object",
            "properties": {
                "value": {"type": "number", "description": "Measurement value in the specified unit"},
                "unit": {"type": "string", "enum": ["Celsius", "Fahrenheit", "Kelvin"], "description": "Unit of measurement"}
            }
        },
        {
            "type": "object",
            "properties": {
                "latitude": {"type": "number", "description": "Latitude coordinate"},
                "longitude": {"type": "number", "description": "Longitude coordinate"},
                "altitude": {"type": "number", "description": "Altitude above sea level"}
            }
        }
    ]
}