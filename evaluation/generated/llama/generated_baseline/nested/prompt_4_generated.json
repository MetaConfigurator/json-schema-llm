{ 
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "fileignoreconfig": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["filename"],
                "properties": {
                    "filename": {"type": "string"},
                    "checksum": {"type": "string", "optional": true},
                    "ignore_detectors": {
                        "type": "array",
                        "items": {"type": "string"}
                    },
                    "allowed_patterns": {
                        "type": "array",
                        "items": {"type": "string"}
                    }
                }
            }
        },
        "scopeconfig": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["scope"]
            }
        },
        "allowed_patterns": {
            "type": "array",
            "items": {"type": "string"}
        },
        "custom_patterns": {
            "type": "array",
            "items": {"type": "string"}
        },
        "custom_severities": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["detector", "severity"],
                "properties": {
                    "detector": {"type": "string"},
                    "severity": {"type": "string", "enum": ["low", "medium", "high"]}
                }
            }
        },
        "threshold": {
            "type": "string",
            "enum": ["low", "medium", "high"]
        },
        "version": {
            "type": "string"
        }
    },
    "required": ["fileignoreconfig", "scopeconfig", "allowed_patterns", "custom_patterns", "custom_severities", "threshold", "version"]