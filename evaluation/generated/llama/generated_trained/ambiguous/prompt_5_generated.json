{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Hospital Patient Record",
  "description": "A Hospital Patient Record is a document containing information about the patient's medical history, current condition, treatment plan, and other relevant details.",
  "type": [
    "object",
    "null"
  ],
  "properties": {
    "patient_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "date_of_birth": {
      "type": "string"
    },
    "age": {
      "type": "number"
    },
    "sex": {
      "enum": [
        "male",
        "female",
        "other"
      ]
    },
    "height": {
      "type": "number"
    },
    "weight": {
      "type": "number"
    },
    "blood_pressure": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "heart_rate": {
      "type": "number"
    },
    "respiratory_rate": {
      "type": "number"
    },
    "systolic_blood_pressure": {
      "type": "number"
    },
    "diastolic_blood_pressure": {
      "type": "number"
    },
    "pulse": {
      "type": "number"
    },
    "temperature": {
      "type": "number"
    },
    "fever": {
      "type": "number"
    },
    "hypertension": {
      "type": "boolean"
    },
    "pulmonary_condition": {
      "type": "string"
    },
    "renal_problem": {
      "type": "boolean"
    },
    "cardiovascular_problem": {
      "type": "boolean"
    },
    "neurological_problem": {
      "type": "boolean"
    },
    "eye_problem": {
      "type": "boolean"
    },
    "skin_problem": {
      "type": "boolean"
    },
    "musculoskeletal_problem": {
      "type": "boolean"
    },
    "cognitive_problem": {
      "type": "boolean"
    },
    "psychological_problem": {
      "type": "boolean"
    },
    "allergy": {
      "type": "boolean"
    },
    "medication": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "treatment_plan": {
      "type": "string"
    },
    "admission_date": {
      "type": "string"
    },
    "discharge_date": {
      "type": "string"
    },
    "discharge_time": {
      "type": "string"
    },
