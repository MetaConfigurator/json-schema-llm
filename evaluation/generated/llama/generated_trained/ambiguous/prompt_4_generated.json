{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "E-commerce Product Catalog",
  "description": "A catalog of products in an e-commerce store.",
  "type": [
    "object",
    "null"
  ],
  "properties": {
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "image": {
            "type": "string"
          }
        }
      }
    }
  }
}