{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Payment Transaction",
  "description": "A payment transaction object",
  "type": "object",
  "properties": {
    "transactionId": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "paymentMethod": {
      "type": "string"
    },
    "cardNumber": {
      "type": "string"
    },
    "cvv": {
      "type": "string"
    },
    "paypalEmail": {
      "type": "string"
    },
    "iban": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    }
  }
}