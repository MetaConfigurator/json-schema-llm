{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Product",
  "description": "A Product",
  "type": "object",
  "properties": {
    "productId": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "price": {
      "type": "number"
    },
    "currency": {
      "type": "string"
    },
    "inStock": {
      "type": "boolean"
    },
    "createdAt": {
      "type": "string"
    }
  }
}