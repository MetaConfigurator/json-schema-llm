{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Patient Record",
  "description": "A patient record object",
  "type": "object",
  "properties": {
    "patientId": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "dateOfBirth": {
      "type": "string"
    },
    "gender": {
      "type": "string"
    },
    "contactInfo": {
      "type": "object",
      "properties": {
        "phone": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    },
    "medicalHistory": {
      "type": "object",
      "properties": {
        "condition": {
          "type": "string"
        },
        "diagnosisDate": {
          "type": "string"
        },
        "medication": {
          "type": "string"
        }
      }
    },
    "allergies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string"
    }
  }
}