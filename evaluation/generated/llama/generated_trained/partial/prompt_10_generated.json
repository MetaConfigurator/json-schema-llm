{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Portfolio",
  "description": "A portfolio is an asset that owns multiple assets.",
  "type": "object",
  "properties": {
    "portfolioId": {
      "type": "string"
    },
    "ownerId": {
      "type": "string"
    },
    "assets": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        },
        "currentValue": {
          "type": "number"
        }
      }
    },
    "totalValue": {
      "type": "number"
    },
    "createdAt": {
      "type": "string"
    }
  }
}