{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Sensor Reading",
  "description": "A sensor reading object",
  "type": "object",
  "properties": {
    "sensorId": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "value": {
      "type": "number"
    },
    "unit": {
      "type": "string"
    },
    "location": {
      "type": "object",
      "properties": {
        "latitude": {
          "type": "number"
        },
        "longitude": {
          "type": "number"
        },
        "altitude": {
          "type": "number"
        }
      }
    },
    "timestamp": {
      "type": "string"
    }
  }
}