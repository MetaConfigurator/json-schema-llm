{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Person",
  "description": "Represents basic information about a person.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "firstName": {
      "type": "string",
      "minLength": 1
    },
    "lastName": {
      "type": "string",
      "minLength": 1
    },
    "age": {
      "type": "integer",
      "minimum": 1
    },
    "email": {
      "type": "string",
      "format": "email"
    }
  },
  "required": ["firstName", "lastName", "age"]
}