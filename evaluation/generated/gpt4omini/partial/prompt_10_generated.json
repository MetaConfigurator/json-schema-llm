{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "portfolioId": {
      "type": "string"
    },
    "ownerId": {
      "type": "string"
    },
    "assets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "currentValue": {
            "type": "number"
          }
        },
        "required": ["type", "symbol", "quantity", "currentValue"]
      }
    },
    "totalValue": {
      "type": "number"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["portfolioId", "ownerId", "assets", "totalValue", "createdAt"]
}