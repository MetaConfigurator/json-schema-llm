{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "postId": {
      "type": "string"
    },
    "userId": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "media": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "likes": {
      "type": "integer"
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "commentText": {
            "type": "string"
          }
        },
        "required": ["userId", "commentText"]
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["postId", "userId", "content", "media", "likes", "comments", "createdAt"]
}