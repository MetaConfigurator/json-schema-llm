{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "asset_id": {
      "type": "string"
    },
    "description": {
      "type": "object",
      "properties": {
        "color": {
          "type": "string"
        },
        "translate": {
          "type": "string"
        }
      },
      "required": ["translate"],
      "additionalProperties": false
    },
    "template_item": {
      "type": "string"
    }
  },
  "required": ["asset_id", "description", "template_item"],
  "additionalProperties": false
}