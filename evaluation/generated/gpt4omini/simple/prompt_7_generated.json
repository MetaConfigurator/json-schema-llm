{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "identifiers": {
      "type": "boolean",
      "default": false
    },
    "ignore": {
      "type": "string",
      "pattern": ".*"
    },
    "jsx": {
      "type": "boolean",
      "default": false
    },
    "reporter": {
      "type": "string",
      "enum": ["default", "json", "pmd"],
      "default": "default"
    },
    "suppress": {
      "type": "integer",
      "default": 100,
      "minimum": 0
    },
    "threshold": {
      "type": "integer",
      "default": 15
    }
  },
  "additionalProperties": false
}