{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "E-commerce Product Catalog",
  "type": "object",
  "properties": {
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": "number",
            "minimum": 0
          },
          "currency": {
            "type": "string",
            "enum": ["USD", "EUR", "GBP", "JPY", "AUD"]
          },
          "category": {
            "type": "string"
          },
          "stock": {
            "type": "integer",
            "minimum": 0
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            }
          },
          "attributes": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "required": ["id", "name", "price", "currency", "stock"]
      }
    }
  },
  "required": ["products"]
}