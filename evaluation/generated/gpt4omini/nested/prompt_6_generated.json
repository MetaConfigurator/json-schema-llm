{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "dynamic": {
      "type": "object",
      "properties": {
        "expand": {
          "type": "boolean",
          "default": false
        },
        "cwd": {
          "type": "string"
        },
        "dest": {
          "type": "string"
        },
        "ext": {
          "type": "string"
        },
        "extDot": {
          "type": "string",
          "enum": ["first", "last"],
          "default": "first"
        },
        "filter": {
          "type": "string",
          "enum": [
            "isFile",
            "isDirectory",
            "isBlockDevice",
            "isCharacterDevice",
            "isSymbolicLink",
            "isFIFO",
            "isSocket"
          ]
        },
        "flatten": {
          "type": "boolean",
          "default": false
        },
        "matchBase": {
          "type": "boolean",
          "default": false
        },
        "nonull": {
          "type": "boolean",
          "default": false
        },
        "rename": {
          "type": "string"
        },
        "src": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "required": ["src"]
    },
    "fileFormat": {
      "type": "object",
      "properties": {
        "files": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "uniqueItems": true
              }
            },
            {
              "type": "array",
              "items": {
                "$ref": "#/definitions/dynamic"
              }
            }
          ]
        }
      }
    }
  },
  "properties": {
    "options": {
      "type": "object"
    }
  },
  "additionalProperties": {
    "oneOf": [
      {
        "$ref": "#/definitions/fileFormat"
      },
      {
        "$ref": "#/definitions/dynamic"
      }
    ]
  }
}