{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "fileignoreconfig": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string"
          },
          "checksum": {
            "type": "string"
          },
          "ignore_detectors": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "filecontent",
                "filename",
                "filesize"
              ]
            }
          },
          "allowed_patterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["filename"],
        "additionalProperties": false
      }
    },
    "scopeconfig": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "scope": {
            "type": "string"
          }
        },
        "required": ["scope"],
        "additionalProperties": false
      }
    },
    "allowed_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "custom_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "custom_severities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "detector": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        },
        "required": ["detector", "severity"],
        "additionalProperties": false
      }
    },
    "threshold": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "version": {
      "type": "string"
    }
  },
  "additionalProperties": false
}