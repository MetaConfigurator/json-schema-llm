{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Embrace Mobile Monitoring SDK Configuration",
  "description": "Configuration schema for the Embrace mobile monitoring SDK.",
  "id": "http://example.com/schemas/embrace-sdk-config-1.0.0.json",
  "type": "object",
  "additionalProperties": true,
  "required": ["app_id", "api_token"],
  "properties": {
    "app_id": {
      "type": "string",
      "minLength": 5,
      "maxLength": 5,
      "description": "Application identifier, exactly five characters long."
    },
    "api_token": {
      "type": "string",
      "minLength": 32,
      "maxLength": 32,
      "description": "Hexadecimal API token, exactly thirty-two characters long."
    },
    "ndk_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enables native crash capture."
    },
    "sdk_config": {
      "type": "object",
      "additionalProperties": true,
      "minProperties": 1,
      "properties": {
        "app": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "report_disk_usage": {
              "type": "boolean",
              "default": true,
              "description": "Whether disk usage collection is enabled."
            }
          }
        },
        "crash_handler": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Controls whether the SDK connects to the uncaught exception handler."
            }
          }
        },
        "networking": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "capture_request_content_length": {
              "type": "boolean",
              "default": true,
              "description": "Whether to capture request content length."
            },
            "disabled_url_patterns": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string"
              },
              "description": "Regular expression patterns used to exclude URLs from capture."
            },
            "enable_native_monitoring": {
              "type": "boolean",
              "default": true,
              "description": "Enables native monitoring."
            },
            "trace_id_header": {
              "type": "string",
              "description": "Header name used for trace IDs."
            }
          }
        },
        "session": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "async_end": {
              "type": "boolean",
              "default": false,
              "description": "Whether to end sessions asynchronously."
            },
            "max_session_seconds": {
              "type": "integer",
              "minimum": 60,
              "description": "Maximum session duration in seconds."
            }
          }
        },
        "startup_moment": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "automatically_end": {
              "type": "boolean",
              "default": true,
              "description": "Whether to automatically end the startup moment."
            },
            "take_screenshot": {
              "type": "boolean",
              "default": false,
              "description": "Whether to take a screenshot at startup."
            }
          }
        },
        "taps": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "capture_coordinates": {
              "type": "boolean",
              "default": true,
              "description": "Whether to capture tap coordinates."
            }
          }
        },
        "webview": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "capture_query_params": {
              "type": "boolean",
              "default": true,
              "description": "Whether to capture query parameters."
            },
            "enable": {
              "type": "boolean",
              "default": true,
              "description": "Controls web view data capture."
            }
          }
        }
      }
    }
  }
}