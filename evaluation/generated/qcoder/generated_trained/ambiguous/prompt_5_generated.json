{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Hospital Patient Record",
  "description": "A schema to validate the format of a hospital patient record.",
  "type": "object",
  "properties": {
    "patient_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "gender": {
      "type": "string"
    },
    "date_of_birth": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "phone_number": {
      "type": "string"
    }
  }
}