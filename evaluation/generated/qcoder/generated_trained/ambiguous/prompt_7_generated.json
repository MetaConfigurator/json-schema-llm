{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Gaming Profile",
  "description": "A schema for the profile of a user in a gaming app.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "username": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "profile_picture_url": {
      "type": "string"
    },
    "gamer_id": {
      "type": "integer"
    },
    "is_active": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}