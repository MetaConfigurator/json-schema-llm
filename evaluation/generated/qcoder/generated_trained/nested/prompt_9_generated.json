    },
    "no_function_formatting": {
      "description": "Do not format function calls.",
      "type": "boolean"
    },
    "no_line_after_yaml": {
      "description": "Do not add newlines after YAML keys.",
      "type": "boolean"
    },
    "no_set_formatting": {
      "description": "Do not set formatter options.",
      "type": "boolean"
    },
    "per_file_ignores": {
