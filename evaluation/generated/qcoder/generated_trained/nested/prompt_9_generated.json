{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "additionalProperties": false,
  "definitions": {
    "css-beautify": {
      "properties": {
        "brace_style": {
          "description": "Brace style to use.",
          "enum": [
            "all",
            "single"
          ],
          "type": "string"
        },
        "end_with_newline": {
          "description": "Should the code be terminated with a newline?",
          "enum": [
            true,
            false
          ],
          "type": "boolean"
        },
        "indent_size": {
          "description": "Indent size to use.",
          "type": "number"
        },
        "insert_final_newline": {
          "description": "Insert final newline after the last statement in a block.",
          "enum": [
            true,
            false
          ],
          "type": "boolean"
        },
        "keep_trailing_comma": {
          "description": "Keep trailing comma when formatting.",
          "enum": [
            true,
            false
          ],
          "type": "boolean"
        },
        "newlines_between_statements": {
          "description": "Newlines between statements should be added or not?",
          "enum": [
            true,
            false
          ],
          "type": "boolean"
        },
        "space_in_parentheses": {
          "description": "Space in parentheses.",
          "enum": [
            true,
            false
          ],
          "type": "boolean"
        }
      },
      "required": [
        "brace_style",
        "indent_size"
      ],
      "type": "object"
    },
    "js-beautify": {
      "properties": {
        "brace_style": {
