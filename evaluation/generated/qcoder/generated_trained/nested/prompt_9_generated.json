      "type": "object"
    },
    "preserve_blank_lines": {
      "description": "Preserve blank lines.",
      "type": "boolean"
    },
    "preserve_leading_space": {
      "description": "Preserve leading space.",
      "type": "boolean"
    },
    "profile": {
      "description": "Profile to use.",
      "enum": [
        "html",
        "django",
        "jinja",
        "nunjucks",
        "handlebars",
        "golang",
        "angular"
      ],
      "type": "string"
    },
    "require_pragma": {
      "description": "Require pragma directive."
    },
    "use_gitignore": {
      "description": "Use gitignore patterns."
