        "insert_final_newline": {
          "description": "Insert final newline after the last statement in a block.",
          "enum": [
            true,
            false
          ],
          "type": "boolean"
        },
        "keep_trailing_comma": {
          "description": "Keep trailing comma when formatting.",
          "enum": [
            true,
            false
          ],
          "type": "boolean"
        },
        "newlines_between_statements": {
          "description": "Newlines between statements should be added or not?",
          "enum": [
            true,
            false
          ],
          "type": "boolean"
        },
        "space_in_parentheses": {
