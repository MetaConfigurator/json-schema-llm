{
    "$schema": "http://json-schema.org/draft-04/schema",
    "description": "A financial portfolio containing multiple assets.",
    "title": "FinancialPortfolio",
    "type": "object",
    "properties": {
        "portfolioId": {"type": "string"},
        "ownerId": {"type": "string"},
        "assets": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "type": {"type": "string"},
                    "symbol": {"type": "string"},
                    "quantity": {"type": "number"},
                    "currentValue": {"type": "number"}
                },
                "required": ["type", "symbol", "quantity", "currentValue"]
            }
        },
        "totalValue": {"type": "number"},
        "createdAt": {"type": "string"}
    },
    "required": ["portfolioId", "ownerId", "assets", "totalValue", "createdAt"]
}