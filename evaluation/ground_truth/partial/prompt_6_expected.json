{
    "$schema": "http://json-schema.org/draft-04/schema",
    "description": "An order placed by a customer in the e-commerce system.",
    "title": "Order",
    "type": "object",
    "properties": {
        "orderId": {
            "description": "Unique identifier for the order",
            "type": "string"
        },
        "customerId": {
            "description": "Identifier for the customer who placed the order",
            "type": "string"
        },
        "items": {
            "description": "List of items in the order",
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "productId": {"type": "string"},
                    "quantity": {"type": "integer"},
                    "price": {"type": "number"}
                },
                "required": ["productId", "quantity", "price"]
            }
        },
        "shippingAddress": {
            "type": "object",
            "properties": {
                "street": {"type": "string"},
                "city": {"type": "string"},
                "zip": {"type": "string"}
            },
            "required": ["street", "city", "zip"]
        },
        "orderDate": {"type": "string"},
        "status": {"type": "string"}
    },
    "required": ["orderId", "customerId", "items", "shippingAddress", "orderDate", "status"]
}